# 复制为 server/.env 并填写（.env 不入 git）。AICC 本地 Gateway 用。
# 百炼 API key —— 只在服务端持有，前端永不接触（Gateway 代理调 DashScope）
DASHSCOPE_API_KEY=
# 单用户 token（可选）：设了则 /api/* 需 Authorization: Bearer <此值>；dist 模式会注入页面
AICC_TOKEN=
# 本地端口（仅绑 127.0.0.1）
PORT=8787
# DashScope OpenAI 兼容端点（一般不用改）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 认知存储 vault 根目录（默认 <项目>/vault）。指向你的 Obsidian 库即可让笔记落到那里：
#   笔记写在 <VAULT_DIR>/{concepts,articles}/*.md。例：指向 Obsidian 库的 AICC 子文件夹
VAULT_DIR=
